// Shutdown
"custom/shutdown": {
	"format": "яАС",
	"on-click": "killall swaynag &> /dev/null; swaynag -t warning -m 'What do you want to do?' -s 'Cancel' -B 'яАг Lock screen' 'swaylock -f -c 000000' -B 'яВЛ Logout' 'swaymsg exit' -B 'яАЮ Reboot' 'systemctl reboot' -B 'яАС Shutdown' 'systemctl poweroff'"
},
}

// Modules configuration
{
 "sway/workspaces": {
     "disable-scroll": true,
     "all-outputs": true,
     "warp-on-scroll": false,
     "format": "{icon}",
     "format-icons": {
         "1": "1",
         "2": "2",
         "3": "3",
         "4": "4",
         //"urgent": "яБк",
